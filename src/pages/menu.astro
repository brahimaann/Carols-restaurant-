---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Menu — Carol's Restaurant | Authentic Liberian Cuisine"
  description="Explore Carol's Restaurant menu featuring authentic Liberian dishes: jollof rice, cassava leaves, fufu, snapper, plantains, and homemade ginger juice."
>
  <!-- ========== MENU HERO ========== -->
  <section class="menu-hero" id="menu-hero">
    <span class="eyebrow">Carol's Restaurant</span>
    <h1>Our Menu</h1>
  </section>

  <!-- ========== MENU IMAGE ========== -->
  <section class="menu-image-section" id="menu-image">
    <img src="/images/carols-menu.png" alt="Carol's Restaurant full menu — appetizers, main dishes, daily soups, drinks, and treats" loading="eager">
  </section>

  <!-- ========== CALL TO ORDER ========== -->
  <section class="menu-cta-section" id="menu-cta">
    <a href="tel:+16122511573" class="cta-btn cta-btn-filled" id="cta-call-order">Call to Order &mdash; (612) 251-1573</a>
  </section>

  <!-- ========== DISH SPOTLIGHTS ========== -->
  <section class="dish-spotlights" id="dish-spotlights">
    <div class="section-header">
      <span class="eyebrow eyebrow-dark">Featured Dishes</span>
      <h2>From Our Kitchen</h2>
      <div class="accent-line accent-line-center" style="background:var(--color-accent-terracotta);"></div>
    </div>

    <!-- Jollof Rice -->
    <div class="dish-spotlight" id="spotlight-jollof">
      <div class="dish-spotlight-img">
        <img src="/images/jollof-rice.png" alt="Jollof rice with chicken quarter and plantains" loading="lazy">
      </div>
      <div class="dish-spotlight-text">
        <span class="eyebrow eyebrow-dark">Main Dish</span>
        <h2>Jollof Rice</h2>
        <p>Our signature jollof rice &mdash; a West African classic cooked low and slow with tomatoes, peppers, and aromatic spices. Served with a golden-crisp chicken quarter and a generous side of sweet fried plantains.</p>
        <div class="price">$18.00</div>
      </div>
    </div>

    <!-- Cassava Leaves -->
    <div class="dish-spotlight reverse" id="spotlight-cassava">
      <div class="dish-spotlight-img">
        <img src="/images/cassava-leaves.png" alt="Cassava leaves soup" loading="lazy">
      </div>
      <div class="dish-spotlight-text">
        <span class="eyebrow eyebrow-dark">Daily Soup</span>
        <h2>Cassava Leaves</h2>
        <p>A beloved Liberian staple &mdash; tender cassava leaves slow-simmered with turkey, chicken, shrimp, and beef in a rich, savory broth. Served with your choice of rice or fufu.</p>
        <div class="price">$16.00</div>
      </div>
    </div>

    <!-- Fufu & Soup -->
    <div class="dish-spotlight" id="spotlight-fufu">
      <div class="dish-spotlight-img">
        <img src="/images/fufu-soup.png" alt="Fufu and palm butter soup" loading="lazy">
      </div>
      <div class="dish-spotlight-text">
        <span class="eyebrow eyebrow-dark">Traditional</span>
        <h2>Fufu &amp; Soup</h2>
        <p>The heart of Liberian cuisine. Choose between traditional plantain fufu or organic cassava fufu, paired with a rich, aromatic soup loaded with turkey, chicken, shrimp, and beef.</p>
        <div class="price">From $16.00</div>
      </div>
    </div>

    <!-- Snapper & Plantains -->
    <div class="dish-spotlight reverse" id="spotlight-snapper">
      <div class="dish-spotlight-img">
        <img src="/images/snapper-plantains.png" alt="Whole grilled snapper with fried plantains" loading="lazy">
      </div>
      <div class="dish-spotlight-text">
        <span class="eyebrow eyebrow-dark">Signature</span>
        <h2>Snapper &amp; Plantains</h2>
        <p>Our showstopper &mdash; a whole red snapper seasoned with bold West African spices, cooked to crispy perfection. Served alongside golden sweet plantains. Made for sharing and savoring.</p>
        <div class="price">$35.00</div>
      </div>
    </div>

    <!-- Plantains with Wings -->
    <div class="dish-spotlight" id="spotlight-plantains">
      <div class="dish-spotlight-img">
        <img src="/images/fried-plantains.png" alt="Fried plantains with chicken wings" loading="lazy">
      </div>
      <div class="dish-spotlight-text">
        <span class="eyebrow eyebrow-dark">Fan Favorite</span>
        <h2>Plantains &amp; Wings</h2>
        <p>Sweet, caramelized fried plantains paired with our house special crispy chicken wings. A perfect combination of sweet and savory that keeps our guests coming back.</p>
        <div class="price">$16.00</div>
      </div>
    </div>
  </section>

  <!-- ========== MARQUEE ========== -->
  <section class="marquee-section" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
    </div>
  </section>
</Layout>
