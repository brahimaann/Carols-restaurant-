---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Carol's Restaurant — Authentic Liberian Cuisine in Brooklyn Center, MN"
  description="Carol's Restaurant serves authentic Liberian home cooking in Brooklyn Center, MN. Enjoy jollof rice, cassava leaves, fufu, fried plantains and more. A taste you will remember."
>
  <!-- ========== HERO ========== -->
  <section class="hero" id="hero">
    <div class="hero-bg">
      <img src="/images/hero-banner.png" alt="Liberian feast spread with jollof rice, plantains, grilled fish and cassava leaves" loading="eager">
    </div>
    <div class="hero-content">
      <p class="hero-motif">Authentic &middot; Savory &middot; Liberian</p>
      <h1><em>Liberian</em><br>Home Cooking</h1>
      <p class="hero-tagline">Bringing the authentic flavors of Liberia to Brooklyn Center, Minnesota. Every dish made with love and tradition.</p>
      <div class="hero-cta-group">
        <a href="/menu" class="cta-btn cta-btn-filled" id="cta-view-menu">View Menu</a>
        <a href="tel:+16122511573" class="cta-btn" id="cta-hero-call">Call to Order</a>
      </div>
    </div>
    <div class="scroll-indicator" aria-hidden="true">
      <span>Scroll</span>
      <div class="scroll-indicator-line"></div>
    </div>
  </section>

  <!-- ========== INFO CARDS (Spotlight hover) ========== -->
  <section class="info-section" id="info-section">
    <div class="info-cards-grid">
      <div class="info-card">
        <div class="info-card-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <h3>Location</h3>
        <p>6940 Brooklyn Blvd<br>Brooklyn Center, MN 55429</p>
      </div>
      <div class="info-card">
        <div class="info-card-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3>Hours</h3>
        <p>Open Daily<br>11:00 AM &ndash; 9:00 PM</p>
      </div>
      <div class="info-card">
        <div class="info-card-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
        </div>
        <h3>Call Us</h3>
        <p><a href="tel:+16122511573">(612) 251-1573</a></p>
      </div>
      <div class="info-card">
        <div class="info-card-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3h18v18H3z"/><path d="M12 8v8"/><path d="M8 12h8"/></svg>
        </div>
        <h3>Dine-In &amp; Takeout</h3>
        <p>Enjoy our authentic Liberian dishes in-house or take them home</p>
      </div>
    </div>
  </section>

  <!-- ========== FOOD GALLERY (user photos prioritized) ========== -->
  <section class="food-gallery" id="food-gallery">
    <div class="section-header">
      <span class="eyebrow">From Our Kitchen</span>
      <h2>A Taste You Will Remember</h2>
      <div class="accent-line accent-line-center"></div>
    </div>
    <div class="food-gallery-grid">
      <div class="food-gallery-item">
        <img src="/images/ginger-juice-promo.jpg" alt="Carol's Famous Ginger Juice" loading="lazy">
        <div class="overlay"><h4>Famous Ginger Juice</h4></div>
      </div>
      <div class="food-gallery-item">
        <img src="/images/fruit-punch-promo.jpg" alt="Carol's Relaxing Fruit Punch" loading="lazy">
        <div class="overlay"><h4>Fruit Punch</h4></div>
      </div>
      <div class="food-gallery-item">
        <img src="/images/worldcup-promo.jpg" alt="World Cup Watch Party at Carol's" loading="lazy">
        <div class="overlay"><h4>Events &amp; Watch Parties</h4></div>
      </div>
      <div class="food-gallery-item">
        <img src="/images/carols-menu.png" alt="Carol's Full Menu" loading="lazy">
        <div class="overlay"><h4>Our Full Menu</h4></div>
      </div>
    </div>
  </section>

  <!-- ========== PROMO / SPECIALS ========== -->
  <section class="promo-section" id="specials">
    <div class="section-header">
      <span class="eyebrow">Specials &amp; Events</span>
      <h2>What's Happening</h2>
      <div class="accent-line accent-line-center"></div>
    </div>
    <div class="promo-grid">
      <div class="promo-card">
        <img src="/images/ginger-juice-promo.jpg" alt="Carol's Famous Ginger Juice — Fresh, Bold, Unforgettable" loading="lazy">
      </div>
      <div class="promo-card">
        <img src="/images/fruit-punch-promo.jpg" alt="Carol's Relaxing Fruit Punch — Great for hot summer weather" loading="lazy">
      </div>
      <div class="promo-card">
        <img src="/images/worldcup-promo.jpg" alt="World Cup Watch Party at Carol's — All games live" loading="lazy">
      </div>
    </div>
  </section>

  <!-- ========== MARQUEE ========== -->
  <section class="marquee-section" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
    </div>
  </section>
</Layout>
