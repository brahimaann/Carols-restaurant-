---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="About — Carol's Restaurant | Our Story"
  description="Learn about Carol's Restaurant — bringing authentic Liberian home cooking and West African flavors to Brooklyn Center, Minnesota."
>
  <!-- ========== PAGE HERO ========== -->
  <section class="page-hero" id="about-hero">
    <div class="hero-bg">
      <img src="/images/hero-banner.png" alt="Liberian feast" loading="eager">
    </div>
    <div class="page-hero-content">
      <span class="eyebrow">Carol's Restaurant</span>
      <h1>Our Story</h1>
    </div>
  </section>

  <!-- ========== ABOUT CONTENT ========== -->
  <section class="about-content" id="about-content">
    <div class="about-grid">
      <div class="about-image gs-reveal-left">
        <img src="/images/carols-logo.png" alt="Carol's Restaurant — A Taste You Will Remember" loading="lazy" style="object-fit:contain; background:var(--color-bg-offwhite); padding:2.5rem;">
      </div>
      <div class="about-text gs-reveal-right">
        <span class="eyebrow eyebrow-dark">Our Heritage</span>
        <h2>Welcome to Carol's</h2>
        <p>Nestled in the heart of Brooklyn Center, Minnesota, Carol's Restaurant is more than just a place to eat &mdash; it's a celebration of Liberian culture, tradition, and the warmth of home-cooked food.</p>
        <p>Every dish on our menu is rooted in the rich culinary heritage of West Africa. From our slow-simmered cassava leaves to our perfectly seasoned jollof rice, each recipe has been passed down through generations and prepared with the same love and care that brings families together.</p>
        <p>At Carol's, we believe food is a bridge &mdash; connecting cultures, building community, and creating memories that last a lifetime. Whether you're a first-time visitor curious about Liberian cuisine or a lifelong fan craving the flavors of home, you'll always find a warm welcome and a full plate here.</p>
        <p><strong>A Taste You Will Remember.</strong></p>
      </div>
    </div>
  </section>

  <!-- ========== VALUES ========== -->
  <section class="values-section" id="values">
    <div class="section-header">
      <span class="eyebrow">Our Values</span>
      <h2>What We Stand For</h2>
      <div class="accent-line accent-line-center"></div>
    </div>
    <div class="values-grid">
      <div class="value-card">
        <div class="icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M12 2a5 5 0 015 5c0 3.5-5 8-5 8s-5-4.5-5-8a5 5 0 015-5z"/><path d="M5 21c0-3 3-5 7-5s7 2 7 5"/></svg>
        </div>
        <h3>Authentic Recipes</h3>
        <p>Every dish is crafted from traditional Liberian recipes, honoring the flavors and techniques of West African home cooking. No shortcuts, no compromises.</p>
      </div>
      <div class="value-card">
        <div class="icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
        </div>
        <h3>Fresh Ingredients</h3>
        <p>We source the freshest ingredients to bring you bold, vibrant flavors in every bite. From our hand-pressed ginger juice to our slow-cooked soups, quality comes first.</p>
      </div>
      <div class="value-card">
        <div class="icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <h3>Community &amp; Culture</h3>
        <p>Carol's is a gathering place &mdash; for families, friends, and neighbors. We're proud to share Liberian culture with Brooklyn Center and beyond through food.</p>
      </div>
    </div>
  </section>

  <!-- ========== GALLERY (user photos) ========== -->
  <section class="food-gallery" id="about-gallery">
    <div class="food-gallery-grid">
      <div class="food-gallery-item">
        <img src="/images/ginger-juice-promo.jpg" alt="Famous Ginger Juice" loading="lazy">
        <div class="overlay"><h4>Ginger Juice</h4></div>
      </div>
      <div class="food-gallery-item">
        <img src="/images/fruit-punch-promo.jpg" alt="Fruit Punch" loading="lazy">
        <div class="overlay"><h4>Fruit Punch</h4></div>
      </div>
      <div class="food-gallery-item">
        <img src="/images/worldcup-promo.jpg" alt="World Cup Watch Party" loading="lazy">
        <div class="overlay"><h4>Watch Parties</h4></div>
      </div>
      <div class="food-gallery-item">
        <img src="/images/carols-menu.png" alt="Our Menu" loading="lazy">
        <div class="overlay"><h4>Full Menu</h4></div>
      </div>
    </div>
  </section>

  <!-- ========== MARQUEE ========== -->
  <section class="marquee-section" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
      <span class="marquee-text">Authentic <span class="motif-icon">&middot;</span> Savory <span class="motif-icon">&middot;</span> Liberian <span class="motif-icon">&middot;</span></span>
    </div>
  </section>
</Layout>
